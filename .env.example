# ==============================================
# Gemini Web Cookies
# ==============================================
# 默认账号 (无后缀)
__Secure-1PSID=
__Secure-1PSIDTS=

# 额外账号 (自定义名称后缀)
# __Secure-1PSID_main=
# __Secure-1PSIDTS_main=
# __Secure-1PSID_work=
# __Secure-1PSIDTS_work=

# ==============================================
# 负载均衡配置
# ==============================================
# 启用的账号列表，支持: [main,work] / {main,work} / main,work
# 留空则自动使用所有已配置的账号
ACCOUNTS=

# ==============================================
# HTTP 代理配置（可选）
# ==============================================
# 全局代理：所有账号默认使用
# 支持：http://host:port / http://user:pass@host:port / socks5://host:port
PROXY=

# 每账号独立代理：覆盖全局 PROXY
# PROXY_main=
# PROXY_work=

# ==============================================
# API 安全配置
# ==============================================
PROXY_API_KEY=sk-123456

# ==============================================
# 服务端口
# ==============================================
PORT=8007

# ==============================================
# 語言配置
# ==============================================
LANGUAGE=en

# ==============================================
# 模型映射 (Claude/OpenAI 模型名 -> Gemini 模型名)
# ==============================================
MODEL_MAPPING=claude-haiku-4-5-20251001:gemini-3-flash-preview-no-thinking

# ==============================================
# Tool Bridge / OpenAI Compat
# ==============================================
# TOOL_SCHEMA_MODE 控制“工具定义”注入给模型时的详细程度。
# 可选值：
# - compact    推荐默认值，兼顾效果和上下文消耗
# - full       完整 schema，最稳但最占上下文
# - names_only 只保留工具名，最省上下文但更容易参数出错
TOOL_SCHEMA_MODE=compact

# 是否启用 search_replace / str_replace 等工具的参数自动修复。
# true  = 启用（推荐）
# false = 关闭
TOOL_ARG_REPAIR_ENABLED=true

# 参数自动修复允许读取的最大文件大小（字节）。
# 常用参考：262144=256KB，524288=512KB，1048576=1MB
TOOL_ARG_REPAIR_MAX_FILE_SIZE=524288

# ==============================================
# CORS / Rate Limit
# ==============================================
# 允许哪些前端域名直接跨域访问本服务。
# 多个来源用英文逗号分隔。
# 留空 = 允许所有来源（*），仅推荐本地测试。
# 示例：
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOWED_ORIGINS=https://chat.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# 每个 IP 每分钟允许的最大请求数。
# 超过会返回 429。
# 建议：
# - 60  轻量公网默认
# - 120 少量用户共用
# - 300 本机/内网高频调试
# - 0 或负数 = 不限制（不建议公网）
RATE_LIMIT_RPM=60
