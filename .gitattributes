# 所有文本文件统一 LF
* text=auto eol=lf

# Windows 脚本必须 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 二进制文件
*.exe binary
*.dll binary
*.so binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary

# Go 相关
*.go text eol=lf
go.mod text eol=lf
go.sum text eol=lf

# 配置文件
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.md text eol=lf

# linguist（GitHub 语言统计）
*.go linguist-language=Go
